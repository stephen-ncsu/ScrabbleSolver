<Window x:Class="ScrabbleUIWPF.TileCorrectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Correct Unrecognized Tiles" 
        Height="750" Width="600"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5"
        ResizeMode="NoResize">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        
        <Style TargetType="TextBox" x:Key="TileCorrectionTextBox">
            <Setter Property="FontSize" Value="48"/>
            <Setter Property="FontFamily" Value="Arial Black"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="MaxLength" Value="1"/>
            <Setter Property="CharacterCasing" Value="Upper"/>
            <Setter Property="Width" Value="100"/>
            <Setter Property="Height" Value="100"/>
            <Setter Property="Background" Value="#FFFACD"/>
            <Setter Property="BorderBrush" Value="#DAA520"/>
            <Setter Property="BorderThickness" Value="3"/>
        </Style>
    </Window.Resources>
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Tile Correction" 
                       FontSize="24" 
                       FontWeight="Bold"
                       HorizontalAlignment="Center"/>
            <TextBlock x:Name="ProgressLabel"
                       Text="Correcting tile 1 of 5"
                       FontSize="14"
                       Foreground="Gray"
                       HorizontalAlignment="Center"
                       Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Current Tile Info -->
        <Border Grid.Row="1" 
                Background="White"
                BorderBrush="#DDD"
                BorderThickness="1"
                Padding="20"
                CornerRadius="5"
                Margin="0,0,0,20">
            <StackPanel>
                <TextBlock x:Name="TileLocationLabel"
                           Text="Board Position: Row 5, Column 8"
                           FontSize="16"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,10"/>
                <TextBlock Text="OCR could not recognize this tile"
                           FontSize="13"
                           Foreground="#666"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,5"/>
                <TextBlock Text="Please enter the correct letter below"
                           FontSize="13"
                           Foreground="#666"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Input Area -->
        <Border Grid.Row="2"
                Background="White"
                BorderBrush="#DDD"
                BorderThickness="1"
                Padding="30"
                CornerRadius="5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Tile Image Preview -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="OCR Image:"
                               FontSize="14"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,10"/>
                    <Border BorderBrush="#DAA520"
                            BorderThickness="3"
                            Background="#F5DEB3"
                            Padding="10"
                            HorizontalAlignment="Center">
                        <Image x:Name="TileImagePreview"
                               Width="150"
                               Height="150"
                               Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                    </Border>
                    <TextBlock Text="What letter do you see?"
                               FontSize="11"
                               Foreground="Gray"
                               HorizontalAlignment="Center"
                               Margin="0,10,0,0"
                               TextWrapping="Wrap"
                               TextAlignment="Center"/>
                </StackPanel>

                <!-- Input Controls -->
                <StackPanel Grid.Column="2" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="Enter Letter:"
                               FontSize="16"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,15"/>

                    <TextBox x:Name="CorrectionTextBox"
                             Style="{StaticResource TileCorrectionTextBox}"
                             TextChanged="CorrectionTextBox_TextChanged"
                             KeyDown="CorrectionTextBox_KeyDown"/>

                    <TextBlock Text="Press Enter to continue"
                               FontSize="12"
                               Foreground="Gray"
                               HorizontalAlignment="Center"
                               Margin="0,15,0,0"/>

                    <CheckBox x:Name="WildcardCheckBox"
                              Content="This is a wildcard/blank tile (*)"
                              FontSize="13"
                              HorizontalAlignment="Center"
                              Margin="0,10,0,0"
                              Checked="WildcardCheckBox_Changed"
                              Unchecked="WildcardCheckBox_Changed"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Summary Panel -->
        <Border Grid.Row="3"
                Background="#E3F2FD"
                BorderBrush="#2196F3"
                BorderThickness="1"
                Padding="15"
                CornerRadius="5"
                Margin="0,20,0,0">
            <StackPanel>
                <TextBlock Text="Corrections Made:" 
                           FontSize="13"
                           FontWeight="SemiBold"
                           Margin="0,0,0,5"/>
                <ScrollViewer MaxHeight="60" VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="CorrectionsListTextBlock"
                               FontFamily="Consolas"
                               FontSize="11"
                               TextWrapping="Wrap"/>
                </ScrollViewer>
            </StackPanel>
        </Border>

        <!-- Navigation Buttons -->
        <Grid Grid.Row="4" Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left">
                <Button x:Name="PreviousButton"
                        Content="⬅ Previous"
                        Click="PreviousButton_Click"
                        IsEnabled="False"
                        Background="LightGray"/>
                <Button x:Name="SkipButton"
                        Content="⏭ Skip"
                        Click="SkipButton_Click"
                        Background="Orange"
                        Foreground="White"/>
            </StackPanel>

            <Button Grid.Column="1"
                    x:Name="FinishButton"
                    Content="✓ Finish Corrections"
                    Click="FinishButton_Click"
                    Background="Green"
                    Foreground="White"
                    FontWeight="Bold"
                    Padding="20,10"
                    Visibility="Collapsed"/>

            <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="NextButton"
                        Content="Next ➡"
                        Click="NextButton_Click"
                        Background="#2196F3"
                        Foreground="White"
                        IsEnabled="False"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
