<Window x:Class="ScrabbleUIWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ScrabbleUIWPF"
        mc:Ignorable="d"
        Title="Scrabble Solver" Height="800" Width="1400"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="10"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Busy Indicator Overlay -->
        <Grid x:Name="BusyOverlay" Grid.RowSpan="5" Grid.Column="0" Grid.ColumnSpan="5" Background="#80000000" Visibility="Collapsed" Panel.ZIndex="1000">
            <Border Background="White" 
                    CornerRadius="10" 
                    Padding="30"
                    HorizontalAlignment="Center" 
                    VerticalAlignment="Center"
                    BorderBrush="#2196F3"
                    BorderThickness="2">
                <StackPanel>
                    <TextBlock x:Name="BusyMessage" 
                               Text="Processing..." 
                               FontSize="16" 
                               FontWeight="Bold"
                               Foreground="#333333"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,15"/>
                    <ProgressBar IsIndeterminate="True" 
                                 Width="300" 
                                 Height="20"
                                 Foreground="#2196F3"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Top Control Panel -->
        <GroupBox Grid.Row="0" Header="Controls" Grid.ColumnSpan="3">
            <!-- File Selection Row -->
            <StackPanel Orientation="Horizontal" Grid.Row="0">
                <Button x:Name="BrowseButton" Content="📁 Browse Image" Click="BrowseButton_Click" MinWidth="150" Height="35"/>
                <Label Content="Selected File:" VerticalAlignment="Center"/>
                <TextBox x:Name="FilePathTextBox" IsReadOnly="True" MinWidth="300" VerticalAlignment="Center"/>
                <Button x:Name="ProcessButton" Content="🔍 Process Image" Click="ProcessButton_Click" MinWidth="150" Height="35"/>
            </StackPanel>
        </GroupBox>

        <!-- Left Panel - Current Board -->
            <GroupBox Grid.Column="0" Grid.Row="1" Header="Current Board State">
                <local:ScrabbleBoardControl x:Name="CurrentBoardControl"/>
            </GroupBox>

            <!-- GridSplitter -->
            <GridSplitter Grid.Column="1" 
                          Width="10" 
                          HorizontalAlignment="Stretch" 
                          Background="Transparent"
                          ShowsPreview="True"/>

        <!-- Right Panel - Moves/Solutions -->
        <GroupBox Grid.Column="2" Grid.Row="1" Header="Move Board State">
            <local:ScrabbleBoardControl x:Name="MovesBoardControl" Grid.Row="1" Grid.Column="2" Margin="5"/>
        </GroupBox>

        <!-- Rack and Solve Row -->
        <StackPanel Orientation="Horizontal" Grid.Row="2" Margin="10" HorizontalAlignment="Center">
            <local:RackControl x:Name="RackControl" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <StackPanel Orientation="Vertical" Margin="10" VerticalAlignment="Center">
                <Button x:Name="SolveButton" Content="🎯 Solve" Click="SolveButton_Click" MinWidth="120" Margin="5" Height="35"/>
                <Button x:Name="CalculateButton" Content="📊 Calculate Scores" Click="CalculateButton_Click" MinWidth="150" Margin="5" Height="35"/>
            </StackPanel>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Grid.Row="2" Grid.Column="2" Margin="10" VerticalAlignment="Center" HorizontalAlignment="Right">
            <Label Content="Move #:" VerticalAlignment="Center" Margin="10"/>
            <TextBox x:Name="MoveIndexTextBox" Text="0" MinWidth="60" VerticalAlignment="Center" Margin="5"/>
            <Button x:Name="ShowMoveButton" Content="👁 Show Move" Click="ShowMoveButton_Click" MinWidth="120" Margin="5" HorizontalAlignment="Right" Height="35"/>
        </StackPanel>

        <!-- Status Bar -->
        <GroupBox Grid.Row="3" Header="Status" Grid.ColumnSpan="3">
            <StackPanel>
                <Border
                            Background="#E3F2FD" 
                            Padding="10" 
                            CornerRadius="4"
                            Margin="5">
                    <TextBlock x:Name="StatusTextBlock" 
                                   Text="Ready to solve..." 
                                   FontSize="13"
                                   Foreground="#1976D2"/>
                </Border>

                <TextBox  x:Name="MoveInfoTextBox" 
                             FontFamily="Consolas" 
                             FontSize="12"
                             IsReadOnly="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             TextWrapping="Wrap"
                             Background="White"
                             Foreground="#333333"
                             Margin="5"
                             MinHeight="80"/>
            </StackPanel>
        </GroupBox>


    </Grid>
</Window>
