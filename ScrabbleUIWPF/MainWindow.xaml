<Window x:Class="ScrabbleUIWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ScrabbleUIWPF"
        mc:Ignorable="d"
        Title="Scrabble Solver" Height="800" Width="1400"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Busy Indicator Overlay -->
        <Grid x:Name="BusyOverlay" Grid.RowSpan="2" Background="#80000000" Visibility="Collapsed" Panel.ZIndex="1000">
            <Border Background="White" 
                    CornerRadius="10" 
                    Padding="30"
                    HorizontalAlignment="Center" 
                    VerticalAlignment="Center"
                    BorderBrush="#2196F3"
                    BorderThickness="2">
                <StackPanel>
                    <TextBlock x:Name="BusyMessage" 
                               Text="Processing..." 
                               FontSize="16" 
                               FontWeight="Bold"
                               Foreground="#333333"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,15"/>
                    <ProgressBar IsIndeterminate="True" 
                                 Width="300" 
                                 Height="20"
                                 Foreground="#2196F3"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Top Control Panel -->
        <GroupBox Grid.Row="0" Header="Controls">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- File Selection Row -->
                <StackPanel Orientation="Horizontal" Grid.Row="0">
                    <Button x:Name="BrowseButton" Content="📁 Browse Image" Click="BrowseButton_Click" MinWidth="150"/>
                    <Label Content="Selected File:" VerticalAlignment="Center"/>
                    <TextBox x:Name="FilePathTextBox" IsReadOnly="True" MinWidth="300" VerticalAlignment="Center"/>
                    <Button x:Name="ProcessButton" Content="🔍 Process Image" Click="ProcessButton_Click" MinWidth="150"/>
                </StackPanel>

                <!-- Rack and Solve Row -->
                <StackPanel Orientation="Horizontal" Grid.Row="1">
                    <Label Content="Rack:" VerticalAlignment="Center"/>
                    <TextBox x:Name="RackTextBox" MinWidth="150" VerticalAlignment="Center" MaxLength="7"/>
                    <Button x:Name="SolveButton" Content="🎯 Solve" Click="SolveButton_Click" MinWidth="120"/>
                    <Button x:Name="CalculateButton" Content="📊 Calculate Scores" Click="CalculateButton_Click" MinWidth="150"/>
                    <Label Content="Move #:" VerticalAlignment="Center"/>
                    <TextBox x:Name="MoveIndexTextBox" Text="0" MinWidth="60" VerticalAlignment="Center"/>
                    <Button x:Name="ShowMoveButton" Content="👁 Show Move" Click="ShowMoveButton_Click" MinWidth="120"/>
                </StackPanel>
            </Grid>
        </GroupBox>

        <!-- Main Content Area -->
        <Grid Grid.Row="1" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel - Current Board -->
            <GroupBox Grid.Column="0" Header="Current Board State">
                <local:ScrabbleBoardControl x:Name="CurrentBoardControl"/>
            </GroupBox>

            <!-- GridSplitter -->
            <GridSplitter Grid.Column="1" 
                          Width="10" 
                          HorizontalAlignment="Stretch" 
                          Background="Transparent"
                          ShowsPreview="True"/>

            <!-- Right Panel - Moves/Solutions -->
            <GroupBox Grid.Column="2" Header="Move Solutions">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Status Bar -->
                    <Border Grid.Row="0" 
                            Background="#E3F2FD" 
                            Padding="10" 
                            CornerRadius="4"
                            Margin="5">
                        <TextBlock x:Name="StatusTextBlock" 
                                   Text="Ready to solve..." 
                                   FontSize="13"
                                   Foreground="#1976D2"/>
                    </Border>

                    <!-- Move Info -->
                    <TextBox x:Name="MoveInfoTextBox" 
                             Grid.Row="1"
                             FontFamily="Consolas" 
                             FontSize="12"
                             IsReadOnly="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             TextWrapping="Wrap"
                             Background="White"
                             Foreground="#333333"
                             Margin="5"
                             MinHeight="80"/>

                    <!-- Moves Board Display -->
                    <local:ScrabbleBoardControl x:Name="MovesBoardControl" Grid.Row="2" Margin="5"/>
                </Grid>
            </GroupBox>
        </Grid>
    </Grid>
</Window>
